{
  "name": "covenant-shared",
  "version": "0.2.7",
  "description": "Shared chain config, types, and contract ABIs for COVENANT agent trust on Pharos",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamedwael201193/COVENANT.git",
    "directory": "packages/shared"
  },
  "keywords": ["pharos", "covenant", "agent-trust", "viem", "eip-712"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "pnpm run generate:abis && tsc",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:abis": "node scripts/generate-abis.mjs"
  },
  "dependencies": {
    "viem": "^2.23.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
