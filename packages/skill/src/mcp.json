{
  "name": "covenant",
  "version": "0.1.0",
  "description": "Stripe for Agent Trust — MCP server for Pharos Atlantic agent preflight",
  "package": "@covenant/mcp",
  "install": "npx @covenant/mcp init",
  "transport": "stdio",
  "command": "npx",
  "args": ["-y", "@covenant/mcp"],
  "chainId": 688689,
  "tools": [
    "covenant_health",
    "covenant_reputation",
    "covenant_preflight",
    "covenant_simulate",
    "covenant_verify_counterparty",
    "covenant_get_receipt",
    "covenant_register_identity",
    "covenant_set_covenant",
    "covenant_rotate_key",
    "covenant_attest_outcome"
  ],
  "docs": {
    "install": "../../docs/skill/INSTALL.md",
    "examples": "../../docs/skill/EXAMPLES.md",
    "agents": "../../AGENTS.md"
  }
}
