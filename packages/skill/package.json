{
  "name": "covenant-skill",
  "version": "0.2.2",
  "description": "COVENANT skill engine — preflight, attestation, and chain layer for agent trust on Pharos",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamedwael201193/COVENANT.git",
    "directory": "packages/skill"
  },
  "keywords": ["mcp", "covenant", "pharos", "agent-trust", "preflight"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/mcp/index.js",
      "types": "./dist/mcp/index.d.ts"
    }
  },
  "bin": {
    "covenant-skill": "./dist/index.js",
    "covenant-mcp": "./dist/mcp/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:env": "tsx scripts/validate-env.ts",
    "validate:goplus": "tsx scripts/validate-goplus.ts",
    "validate:llm": "tsx scripts/validate-llm.ts"
  },
  "dependencies": {
    "covenant-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "pino": "^9.6.0",
    "viem": "^2.23.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
