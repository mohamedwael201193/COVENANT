# Pharos Atlantic Testnet — https://docs.pharos.xyz/getting-started/network/atlantic-testnet
PHAROS_CHAIN_ID=688689
PHAROS_RPC_URL=https://api.zan.top/node/v1/pharos/atlantic/YOUR_KEY
PHAROS_RPC_URL_FALLBACK=https://atlantic.dplabs-internal.com
PHAROS_WSS_URL=
PHAROS_EXPLORER_URL=https://atlantic.pharosscan.xyz
PHAROS_EXPLORER_API_KEY=

# Fresh testnet-only wallet — https://metamask.io
DEPLOYER_PRIVATE_KEY=0x

# GoPlus — https://console.gopluslabs.io
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
GOPLUS_API_BASE=https://api.gopluslabs.io

# LLM providers (at least one required for explainer)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.3-70b
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# IPFS — https://pinata.cloud
PINATA_JWT=

# Postgres — Supabase (eu-west-3): use Session pooler URL, NOT direct db.* (IPv6-only)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.pgwqtowdmyqmyolxocmw:password@aws-0-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require

# Redis — https://upstash.com (use rediss:// for TLS)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# Skill server
SKILL_SERVER_PORT=8787
SKILL_SERVER_HOST=0.0.0.0
MCP_STDIO_ENABLED=false
PORT=

# Indexer
INDEXER_HTTP_PORT=8788
INDEXER_HTTP_HOST=0.0.0.0
INDEXER_START_BLOCK=24340730
INDEXER_POLL_INTERVAL_MS=12000
INDEXER_ORACLE_ENABLED=true

# CertiK — WAITING_FOR_OFFICIAL_ACCESS
CERTIK_SCANNER_URL=
CERTIK_SCANNER_API_KEY=
